{
  "name": "hormonerx-benchmark",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An open evidence dataset and benchmark for testing whether AI systems can recognize hormonal medication context and retrieve verified interaction evidence without generating unsupported clinical advice.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --port 4173 --strictPort",
    "benchmark": "tsx scripts/run_benchmark.ts",
    "backend": "backend/.venv/bin/uvicorn app.main:app --port 8000 --app-dir backend",
    "backend:test": "cd backend && .venv/bin/python -m pytest -q",
    "benchmark:backend": "cd backend && .venv/bin/python -m app.benchmark --layer all",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.61.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
