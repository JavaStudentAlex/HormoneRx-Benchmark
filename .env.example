# HormoneRx Benchmark — environment configuration
#
# DEMO mode needs NO API key. It uses the deterministic extractor and cached demo cases.
# LIVE mode calls a server-side/serverless /api/extract endpoint that performs a
# structured-output model call. Secrets are read ONLY on the server and are NEVER exposed
# to the browser. Do not prefix these with VITE_ (that would leak them into client code).

# Model provider credentials (server-side only)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Optional: base URL for an OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1
