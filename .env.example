# HormoneRx — environment configuration
#
# DEMO mode needs NO API key: deterministic extractor, scripted demo replay, text
# fallback. LIVE mode adds realtime microphone transcription and structured-output
# model extraction; secrets are read ONLY by the backend server and are NEVER exposed
# to the browser. Do not prefix secrets with VITE_ (that would leak them into client code).

# ---- Backend (TypeScript, backend/) ---------------------------------------
APP_ENV=development
DEMO_MODE=true

# Model provider credentials (server-side only; required for live mode)
OPENAI_API_KEY=
# Optional OpenAI-compatible base URL
# OPENAI_BASE_URL=https://api.openai.com/v1

# Realtime speech-to-text (spec §7.3 — must stay configurable; test with real audio)
TRANSCRIPTION_MODEL=gpt-realtime-whisper
TRANSCRIPTION_LANGUAGE=en

# Structured-output extraction model (live mode)
EXTRACTION_MODEL=gpt-4o-mini

# Evidence dataset (single canonical file, also imported by the frontend)
EVIDENCE_PATH=backend/data/evidence_records.json
STRICT_EVIDENCE_VALIDATION=true

# Hackathon-demo override: lets records that pass every runtime check EXCEPT the
# physician sign-off flag produce warnings, each visibly labeled
# "physician sign-off pending". Forced off when APP_ENV=production. After the
# physician flips physicianVerified to true in the evidence file, this is irrelevant.
EVIDENCE_ALLOW_PENDING_VERIFICATION=true

# Fall back to the deterministic extractor when live extraction fails
EXTRACTION_FALLBACK_DETERMINISTIC=true

# Privacy defaults (spec §28): never persist audio; transcripts in-memory only
STORE_RAW_AUDIO=false
STORE_TRANSCRIPTS=false

# ---- Agent fleet (docs/FLEET.md) ------------------------------------------
# Always-running workers over the encounter event log. 17 registered; with the
# defaults below 15 run.
FLEET_ENABLED=true
# Washout-window sentinel: PROPOSED behavior (records state 28-day/4-week risk
# persistence after stopping an enzyme inducer). Advisory-only even when on;
# stays off until the physician signs it off. Forced off in production.
FLEET_WASHOUT_SENTINEL=false
# Outbound checks of evidence source URLs (content-drift detection). Off by
# default so dev/CI runs make no network egress.
FLEET_LINK_CHECK=false
# FLEET_LINK_INTERVAL_MIN=360
# FLEET_WATCHDOG_INTERVAL_S=60

LOG_LEVEL=INFO
